generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Tenant {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users           User[]
  agents          Agent[]
  telemetryEvents TelemetryEvent[]
  alerts          Alert[]

  @@map("tenants")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  role         Role     @default(analyst)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenantId String
  tenant   Tenant @relation(fields: [tenantId], references: [id])

  refreshTokens  RefreshToken[]
  assignedAlerts Alert[]        @relation("AssignedAlerts")
  enrolledAgents Agent[]        @relation("EnrolledAgents")

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  isRevoked Boolean  @default(false)
  expiresAt DateTime
  createdAt DateTime @default(now())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  @@map("refresh_tokens")
}

enum Role {
  owner
  admin
  analyst
  read_only

  @@map("role")
}

model Agent {
  id       String @id @default(uuid())
  tenantId String

  // Identity fields
  displayName  String
  hostname     String
  os           String
  agentVersion String

  // Credential — SHA-256(raw_token) only; raw token returned once at enrollment
  tokenHash   String @unique
  tokenPrefix String // first 17 chars of raw token — safe for support identification

  // Lifecycle
  status           AgentStatus @default(pending)
  enrolledByUserId String
  pendingExpiresAt DateTime // enrollment window; pending tokens auto-expire

  // Telemetry context
  lastSeenAt       DateTime?
  lastIpHash       String? // SHA-256(ip + IP_HASH_SALT) — never raw IP
  lastAgentVersion String?
  ipAddress        String? // @deprecated — retained for migration window; use lastIpHash

  // Response containment (platform-side intent; endpoint enforcement deferred)
  isolatedAt DateTime?

  // Timestamps
  registeredAt DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  enrolledBy      User             @relation("EnrolledAgents", fields: [enrolledByUserId], references: [id])
  telemetryEvents TelemetryEvent[]
  alerts          Alert[]

  @@index([tenantId, status])
  @@index([tenantId, lastSeenAt])
  @@index([tenantId, isolatedAt])
  @@map("agents")
}

model TelemetryEvent {
  id         String   @id @default(uuid())
  tenantId   String
  agentId    String
  eventType  String
  severity   String
  occurredAt DateTime
  payload    Json
  receivedAt DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id])
  agent  Agent  @relation(fields: [agentId], references: [id])
  alert  Alert?

  @@index([tenantId, receivedAt])
  @@index([agentId, receivedAt])
  @@map("telemetry_events")
}

enum AlertStatus {
  open
  acknowledged
  resolved

  @@map("alert_status")
}

model Alert {
  id               String      @id @default(uuid())
  tenantId         String
  agentId          String
  telemetryEventId String?     @unique
  title            String
  severity         String
  status           AlertStatus @default(open)
  ruleId           String?
  assignedToId     String?
  resolvedAt       DateTime?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  agent          Agent           @relation(fields: [agentId], references: [id])
  telemetryEvent TelemetryEvent? @relation(fields: [telemetryEventId], references: [id])
  assignedTo     User?           @relation("AssignedAlerts", fields: [assignedToId], references: [id])

  @@index([tenantId, status, createdAt])
  @@index([tenantId, ruleId])
  @@index([agentId])
  @@map("alerts")
}

enum AgentStatus {
  pending
  active
  inactive
  revoked
  expired

  @@map("agent_status")
}
